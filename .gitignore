# HeyPDF 2.0 — .gitignore

# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg
.eggs/

# Virtual environments
venv/
.venv/
env/
ENV/

# Environment variables (NEVER commit your real keys)
.env
.env.*
!.env.example

# HeyPDF storage (FAISS indexes and uploaded PDF data)
backend/storage/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Frontend build artifacts
frontend/node_modules/
frontend/dist/

# Python test cache
.pytest_cache/
.coverage
htmlcov/
