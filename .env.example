# HeyPDF 2.0 — Environment Variables Example
# Copy this file to .env and fill in your actual API keys.
# At least ONE key from ONE provider is required to run the app.
# Add more keys (_2, _3 ...) to increase your rate limit capacity.

# ── Groq API Keys (tried first) ──────────────────────────────────────────────
# Get free keys at: https://console.groq.com
GROQ_API_KEY_1=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_2=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Gemini API Keys (tried second) ───────────────────────────────────────────
# Get free keys at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY_1=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY_2=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── OpenRouter API Keys (tried third — free models only) ─────────────────────
# Get free keys at: https://openrouter.ai/keys
OPENROUTER_API_KEY_1=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_API_KEY_2=

# ── HuggingFace API Keys (tried last) ────────────────────────────────────────
# Get free keys at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY_1=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HUGGINGFACE_API_KEY_2=
